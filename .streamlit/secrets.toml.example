# Copy this to .streamlit/secrets.toml and fill in your values
# On Streamlit Cloud, add these under App Settings > Secrets

[supabase]
url = "https://your-project-id.supabase.co"
key = "your-supabase-anon-key"

[anthropic]
api_key = "your-anthropic-api-key" # Used for Claude RAG agent (Claude 3.5 Sonnet)
openrouter_key = "your-openrouter-api-key" # Fallback Llama 3.1 8B Free
gemini_key = "your-gemini-api-key" # Fallback Gemini 1.5 Flash
groq_key = "your-groq-api-key" # Fallback Llama 3.3 70B
huggingface_key = "your-huggingface-api-key"

[fred]
api_key = "your-fred-api-key" # Free at https://fred.stlouisfed.org/docs/api/api_key.html
